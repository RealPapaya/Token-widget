{
  "name": "claude-usage-widget",
  "version": "1.0.0",
  "description": "Windows desktop widget showing Claude Code usage limits with countdown",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:win": "npx --yes electron-builder --win portable && node scripts/copy-release-exe.js",
    "gen-icon": "node scripts/gen-tray-icon.js"
  },
  "build": {
    "appId": "com.morrishsueh.claudeusagewidget",
    "productName": "Claude Usage Widget",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "artifactName": "${productName}.${ext}",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "author": "morris_hsueh",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0"
  }
}
