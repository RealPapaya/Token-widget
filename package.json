{
  "name": "claude-usage-widget",
  "version": "1.0.0",
  "description": "Desktop widget showing Claude Code, Codex, and API usage limits with countdown",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:win": "npx --yes electron-builder --win portable && node scripts/copy-release-exe.js",
    "dist:mac": "node scripts/gen-tray-icon.js && npx --yes electron-builder --mac dmg zip",
    "gen-icon": "node scripts/gen-tray-icon.js && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/gen-app-icon.ps1",
    "gen-icon:mac": "node scripts/gen-tray-icon.js"
  },
  "build": {
    "appId": "com.morrishsueh.claudeusagewidget",
    "productName": "Claude Usage Widget",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "artifactName": "usage widget.${ext}",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/app.ico"
    },
    "mac": {
      "artifactName": "usage widget-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "icon": "assets/app.icns",
      "extendInfo": {
        "LSUIElement": true
      }
    }
  },
  "author": "morris_hsueh",
  "license": "MIT",
  "devDependencies": {
    "electron": "33.4.11"
  }
}
